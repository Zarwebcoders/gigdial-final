{
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "https://gigdial-backend.vercel.app/api/$1"
        },
        {
            "source": "/uploads/(.*)",
            "destination": "https://gigdial-backend.vercel.app/uploads/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}